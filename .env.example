# Firebase configuration for cross-browser real-time sync.
# Create a free Firebase project at https://console.firebase.google.com
# Then enable Firestore (in Native mode) and copy the config values below.
#
# For local development: copy this file to .env and fill in your values.
# For GitHub Pages deployment: add these as repository secrets in GitHub:
#   Settings > Secrets and variables > Actions > New repository secret
#   Then the GitHub Actions workflow will inject them at build time.
#
# The app works without these — sync will be disabled and data is stored locally only.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
